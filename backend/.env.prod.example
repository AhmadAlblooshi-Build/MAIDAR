# MAIDAR Backend Environment Configuration
# PRODUCTION Environment - Copy to .env.prod and update values

# Application
APP_NAME=MAIDAR
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1
FRONTEND_URL=https://your-domain.com

# Database (PostgreSQL) - using psycopg3 driver
DATABASE_URL=postgresql+psycopg://user:password@db-host:5432/maidar_production
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security
# IMPORTANT: Generate new secret key for production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption (AES-256)
# IMPORTANT: Generate new encryption key for production
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-IN-PRODUCTION

# TLS/SSL
USE_TLS=True
TLS_VERSION=TLSv1.3

# Data Residency & Compliance
DATA_RESIDENCY_REGION=UAE
COMPLIANCE_MODE=UAE_PDPL

# Redis
REDIS_URL=redis://redis-host:6379/0

# CORS
CORS_ORIGINS=["https://your-domain.com","https://api.your-domain.com"]

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Risk Engine
RISK_ENGINE_VERSION=v1.0

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@your-domain.com
FROM_NAME=MAIDAR

# Claude AI API (for AI scenario generation)
ANTHROPIC_API_KEY=sk-ant-api03-your-actual-api-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Session
SESSION_SECRET_KEY=CHANGE-THIS-TO-A-DIFFERENT-SECURE-RANDOM-KEY
