# MAIDAR Backend Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=MAIDAR
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL) - using psycopg3 driver
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/maidar
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption (AES-256)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# TLS/SSL
USE_TLS=True
TLS_VERSION=TLSv1.3

# Data Residency & Compliance
DATA_RESIDENCY_REGION=UAE
COMPLIANCE_MODE=UAE_PDPL

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Monitoring (optional)
SENTRY_DSN=

# Risk Engine
RISK_ENGINE_VERSION=v1.0

# Email (SMTP)
# Leave empty for development mode (emails will be logged instead of sent)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@maidar.com
FROM_NAME=MAIDAR
